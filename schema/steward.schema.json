{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SPLRAD Steward manifest",
  "description": "Versioned repository configuration consumed from the default branch.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "automation", "features"],
  "properties": {
    "$schema": {
      "type": "string",
      "pattern": "^https://raw\\.githubusercontent\\.com/splrad/steward/[0-9a-f]{40}/schema/steward\\.schema\\.json$"
    },
    "schemaVersion": {
      "const": 1
    },
    "automation": {
      "$ref": "#/$defs/automation"
    },
    "features": {
      "$ref": "#/$defs/features"
    },
    "classification": {
      "$ref": "#/$defs/classification"
    },
    "release": {
      "$ref": "#/$defs/release"
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "features": {
            "type": "object",
            "properties": {
              "classification": { "const": true }
            },
            "required": ["classification"]
          }
        }
      },
      "then": {
        "type": "object",
        "properties": { "classification": { "$ref": "#/$defs/classification" } },
        "required": ["classification"]
      },
      "else": {
        "type": "object",
        "not": { "required": ["classification"] }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "features": {
            "type": "object",
            "properties": {
              "release": { "const": true }
            },
            "required": ["release"]
          }
        }
      },
      "then": {
        "type": "object",
        "properties": { "release": { "$ref": "#/$defs/release" } },
        "required": ["release"]
      },
      "else": {
        "type": "object",
        "not": { "required": ["release"] }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\u0000]+$"
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["githubApp", "maintainers", "language"],
      "properties": {
        "githubApp": {
          "type": "object",
          "additionalProperties": false,
          "required": ["clientId", "slug"],
          "properties": {
            "clientId": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]+$",
              "minLength": 10,
              "maxLength": 128
            },
            "slug": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
              "maxLength": 100
            }
          }
        },
        "maintainers": {
          "oneOf": [
            { "$ref": "#/$defs/organizationTeamMaintainers" },
            { "$ref": "#/$defs/userMaintainers" }
          ]
        },
        "language": {
          "enum": ["zh-CN"]
        }
      }
    },
    "organizationTeamMaintainers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "teamSlug"],
      "properties": {
        "source": { "const": "organization-team" },
        "teamSlug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "maxLength": 100
        }
      }
    },
    "userMaintainers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "logins"],
      "properties": {
        "source": { "const": "users" },
        "logins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prAutomation",
        "classification",
        "dcoAdvisory",
        "governance",
        "copilotReview",
        "release",
        "webhookRelay"
      ],
      "properties": {
        "prAutomation": { "type": "boolean" },
        "classification": { "type": "boolean" },
        "dcoAdvisory": { "type": "boolean" },
        "governance": { "type": "boolean" },
        "copilotReview": { "type": "boolean" },
        "release": { "type": "boolean" },
        "webhookRelay": { "type": "boolean" }
      }
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "pathArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/repoPath" }
    },
    "area": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "patterns"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "patterns": { "$ref": "#/$defs/pathArray" }
      }
    },
    "publicLabel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "color", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "color": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{6}$"
        },
        "description": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "releaseCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "releaseLabel",
        "labels",
        "textPatterns",
        "installOrPackage",
        "fallback"
      ],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "releaseLabel": { "$ref": "#/$defs/nonEmptyString" },
        "labels": { "$ref": "#/$defs/stringArray" },
        "textPatterns": { "$ref": "#/$defs/stringArray" },
        "installOrPackage": { "type": "boolean" },
        "fallback": { "type": "boolean" }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "areas",
        "runtimeRelease",
        "installOrPackage",
        "labels",
        "releaseCategories"
      ],
      "properties": {
        "areas": {
          "type": "array",
          "items": { "$ref": "#/$defs/area" }
        },
        "runtimeRelease": {
          "type": "object",
          "additionalProperties": false,
          "required": ["includePrefixes", "includeFiles", "excludePrefixes", "excludeFiles"],
          "properties": {
            "includePrefixes": { "$ref": "#/$defs/pathArray" },
            "includeFiles": { "$ref": "#/$defs/pathArray" },
            "excludePrefixes": { "$ref": "#/$defs/pathArray" },
            "excludeFiles": { "$ref": "#/$defs/pathArray" }
          }
        },
        "installOrPackage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["includeFiles"],
          "properties": {
            "includeFiles": { "$ref": "#/$defs/pathArray" }
          }
        },
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "required": ["public", "release", "internalPrefixes"],
          "properties": {
            "public": {
              "type": "array",
              "items": { "$ref": "#/$defs/publicLabel" }
            },
            "release": { "$ref": "#/$defs/stringArray" },
            "internalPrefixes": { "$ref": "#/$defs/stringArray" }
          }
        },
        "releaseCategories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/releaseCategory" }
        }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggerPaths", "runner", "adapterCommand"],
      "properties": {
        "triggerPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repoPath" }
        },
        "runner": { "$ref": "#/$defs/nonEmptyString" },
        "adapterCommand": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    }
  }
}
