{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ES2024",
    "types": ["node", "vitest/globals"]
  },
  "include": ["action/src/**/*.ts", "packages/**/*.ts", "tests/**/*.ts"],
  "exclude": [
    "packages/relay/**/*.ts",
    "packages/coordinator/**/*.ts",
    "packages/control-runtime/**/*.ts",
    "packages/ingress/**/*.ts"
  ]
}
