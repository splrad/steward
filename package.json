{
  "name": "@splrad/steward",
  "private": true,
  "description": "Shared event-driven repository automation for SPLRAD projects.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "steward": "packages/cli/dist/index.js"
  },
  "engines": {
    "node": "24.14.1"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "deploy:relay": "wrangler deploy --config packages/relay/wrangler.toml",
    "test": "vitest run",
    "test:workerd": "npm run test:workerd:coordinator && npm run test:workerd:control",
    "test:workerd:control": "vitest run --config vitest.control-workerd.config.ts",
    "test:workerd:coordinator": "vitest run --config vitest.workerd.config.ts",
    "test:relay": "vitest run packages/relay/test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json && tsc -p tsconfig.runtime.json && tsc -p workerd-tests/tsconfig.json && tsc -p packages/relay/tsconfig.json",
    "verify": "npm run test && npm run test:workerd && npm run typecheck && npm run verify:dist && npm run verify:workflows",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify:workflows": "node scripts/verify-workflows.mjs"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@octokit/auth-app": "8.2.0",
    "libsodium-wrappers": "0.8.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.8",
    "@cloudflare/workers-types": "5.20260723.1",
    "@types/node": "26.1.1",
    "@vercel/ncc": "0.44.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.114.0",
    "yaml": "2.9.0"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "sharp": "0.35.3"
  }
}
