{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "steward-ingress",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-23",
  "workers_dev": false,
  "preview_urls": false,
  "secrets": {
    "required": [
      "GITHUB_WEBHOOK_SECRET"
    ]
  },
  "queues": {
    "producers": [
      {
        "binding": "EVENT_QUEUE",
        "queue": "steward-events"
      }
    ]
  }
}
